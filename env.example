# XCTimer environment — copy to `env` (git-ignored) and fill in.
# Reuse ANTHROPIC_API_KEY + RESEND_API_KEY from an existing app (handoff §6).

# --- AI (Claude) ---
ANTHROPIC_API_KEY=
XC_CLAUDE_MODEL=claude-sonnet-5

# --- Email (Resend) for invite/setup/reset links ---
RESEND_API_KEY=
XC_MAIL_FROM=noreply@xctimer.com
XC_MAIL_FROM_NAME=XCTimer

# --- URLs / bind ---
XC_PUBLIC_URL=https://xctimer.com
XC_HOST=127.0.0.1
XC_PORT=5006

# --- App secret (Flask session signing) ---
XCTIMER_SECRET=change-me-to-a-random-string
